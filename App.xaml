<Application x:Class="RadcKioskLauncher.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:RadcKioskLauncher.Helpers"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <helpers:IconConverter x:Key="IconConverter" />
        <SolidColorBrush x:Key="BackgroundBrush" Color="#11151D" />
        <SolidColorBrush x:Key="PanelBrush" Color="#1E2633" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2D7DFF" />
        <SolidColorBrush x:Key="TextBrush" Color="#E9EEF6" />
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Margin" Value="8" />
            <Setter Property="FontSize" Value="18" />
        </Style>
    </Application.Resources>
</Application>
