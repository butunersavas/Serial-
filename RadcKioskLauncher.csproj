<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <AssemblyName>RadcKioskLauncher</AssemblyName>
    <RootNamespace>RadcKioskLauncher</RootNamespace>
    <ApplicationManifest>app.manifest</ApplicationManifest>
  </PropertyGroup>

  <ItemGroup>
    <None Include="Samples\config.sample.json" CopyToOutputDirectory="PreserveNewest" />
    <None Include="Properties\PublishProfiles\win-x64-singlefile.pubxml" />
  </ItemGroup>
</Project>
