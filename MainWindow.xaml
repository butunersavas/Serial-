<Window x:Class="RadcKioskLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:RadcKioskLauncher.Views"
        mc:Ignorable="d"
        Title="RADC Kiosk Launcher"
        WindowStyle="None"
        WindowState="Maximized"
        Topmost="True"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PanelBrush}" Padding="16,8">
            <DockPanel>
                <TextBlock Text="{Binding DeviceName}" FontSize="18" VerticalAlignment="Center" DockPanel.Dock="Left"/>
                <TextBlock Text="LAN: N/A" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" />
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <TextBlock Text="{Binding Clock}" FontSize="18" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <Button Command="{Binding HiddenCornerTapCommand}" Content="●" Width="28" Height="28" Padding="0" Margin="0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="24">
            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowAdminMode}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Apps}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource PanelBrush}" CornerRadius="10" Width="240" Height="180" Margin="10">
                                    <Button Command="{Binding DataContext.LaunchAppCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Image Source="{Binding IconPath, Converter={StaticResource IconConverter}}" Width="64" Height="64" Margin="0,0,0,10"/>
                                            <TextBlock Text="{Binding Title}" HorizontalAlignment="Center" FontSize="20" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Button>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <views:AdminView DataContext="{Binding AdminViewModel}">
                <views:AdminView.Style>
                    <Style TargetType="views:AdminView">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowAdminMode}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </views:AdminView.Style>
            </views:AdminView>
        </Grid>

        <Border Grid.Row="2" Background="{StaticResource PanelBrush}" Padding="12,6">
            <DockPanel>
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" FontSize="15"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="Yenile" Command="{Binding RefreshCommand}" FontSize="14" Padding="12,4"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
