<Window x:Class="RadcKioskLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:RadcKioskLauncher.Views"
        mc:Ignorable="d"
        Title="RADC Kiosk Launcher"
        WindowStyle="None"
        WindowState="Maximized"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="58"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="42"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PanelBrush}" Padding="18,8">
            <DockPanel LastChildFill="False">
                <TextBlock Text="{Binding DeviceAndIp}" FontSize="19" VerticalAlignment="Center" DockPanel.Dock="Left"/>
                <Border DockPanel.Dock="Right" Width="24" Height="24" Background="Transparent" CornerRadius="4"
                        ToolTip="{Binding AdminEntryTooltip}"
                        MouseLeftButtonDown="AdminTrigger_OnMouseDown"
                        MouseLeftButtonUp="AdminTrigger_OnMouseUp"/>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="16">
            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowAdminMode}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Apps}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource PanelBrush}" CornerRadius="12" Width="220" Height="156" Margin="8">
                                    <Button Command="{Binding DataContext.LaunchAppCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Image Source="{Binding IconPath, Converter={StaticResource IconConverter}}" Width="56" Height="56" Margin="0,0,0,8"/>
                                            <TextBlock Text="{Binding Title}" HorizontalAlignment="Center" FontSize="18" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Button>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <Border Background="#DD11151D" CornerRadius="12" Padding="12">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowAdminMode}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <views:AdminView DataContext="{Binding AdminViewModel}">
                    <views:AdminView.Style>
                        <Style TargetType="views:AdminView">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowAdminMode}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </views:AdminView.Style>
                </views:AdminView>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="{StaticResource PanelBrush}" Padding="12,6">
            <DockPanel>
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" FontSize="14"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="{Binding RefreshButtonText}" Command="{Binding RefreshCommand}" FontSize="14" Padding="12,4"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Background="#CC000000" Grid.RowSpan="3">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowPinOverlay}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border Width="420" Padding="16" Background="{StaticResource PanelBrush}" CornerRadius="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Yönetici PIN girin" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                    <PasswordBox x:Name="AdminPinBox" FontSize="22" MaxLength="12" KeyDown="AdminPinBox_OnKeyDown"/>
                    <TextBlock Text="{Binding PinErrorMessage}" Foreground="#FF8080" Margin="0,8,0,0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                        <Button Content="İptal" Width="96" Margin="0,0,8,0" Click="AdminPinCancel_OnClick"/>
                        <Button Content="Giriş" Width="96" Click="AdminPinSubmit_OnClick"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
